   "source": [
    "# re-imagine what offsetting transactions would have occurred in a like-for-like framework\n",
    "# NOTE: this could also be done with CARB's GWP values on the long-lived side... \n",
    "\n",
    "pf_lfl = project_fluxes[project_fluxes['year'] <= 2025].copy()\n",
    "\n",
    "# sum short-lived bucket across all years (everything in tCH4)\n",
    "total_ch4_supply = pf_lfl['ch4_flux'].abs().sum()\n",
    "total_ch4_demand = justified_emission_fluxes['ch4_justified'].sum()\n",
    "\n",
    "# sum long-lived bucket across all years (everything in tCO2e w/ gwp100)\n",
    "total_longlife_supply = (\n",
    "    pf_lfl['co2_flux'].abs().sum() +\n",
    "    pf_lfl['cfc-12_flux'].abs().sum() * gwp_100['cfc-12']\n",
    ")\n",
    "total_longlife_demand = (\n",
    "    justified_emission_fluxes['co2_justified'].sum() +\n",
    "    justified_emission_fluxes['n2o_justified'].sum() * gwp_100['n2o']\n",
    ")\n",
    "\n",
    "# like-for-like matching\n",
    "ch4_matched       = min(total_ch4_supply, total_ch4_demand)\n",
    "longlived_matched = min(total_longlife_supply, total_longlife_demand)\n",
    "like_for_like_total = longlived_matched + ch4_matched\n",
    "\n",
    "print(f\"CH4 supply:          {total_ch4_supply:,.0f} tCH4\")\n",
    "print(f\"CH4 demand:          {total_ch4_demand:,.0f} tCH4\")\n",
    "print(f\"CH4 matched:         {ch4_matched:,.0f} tCH4\")\n",
    "print(f\"\")\n",
    "print(f\"Long-lived supply:   {total_longlife_supply:,.0f} tCO2e\")\n",
    "print(f\"Long-lived demand:   {total_longlife_demand:,.0f} tCO2e\")\n",
    "print(f\"Long-lived matched:  {longlived_matched:,.0f} tCO2e\")\n",
    "print(f\"\")\n",
    "print(f\"Like-for-like total:  {like_for_like_total:,.0f} offsets\")"
   ]
  },
