     },
     "execution_count": 15,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# calculate difference between the sum of covered+uncovered and the total emissions\n",
    "\n",
    "total_differences = (\n",
    "    combined_df\n",
    "    .assign(\n",
    "        difference=lambda x: ((x['total_covered_co2e'] + x['total_non_coverned_co2e']) - \n",
    "                             (x['total_co2e'])).round(2)\n",
    "    )\n",
    ")[['facility_id', 'report_year', 'total_co2e', 'total_covered_co2e', 'total_non_coverned_co2e', 'difference']]\n",
    "\n",
    "total_differences[total_differences['difference'] > 1].groupby('report_year')['facility_id'].count()"
   ]
  },
