   "source": [
    "# export the like-for-like experiment as a csv\n",
    "\n",
    "# get the original project and justified emission fluxes\n",
    "lfl = project_fluxes.copy()\n",
    "lfl = lfl.merge(justified_emission_fluxes[['year', 'co2_justified', 'ch4_justified', 'n2o_justified']], on='year', how='left')\n",
    "lfl = lfl.fillna(0)\n",
    "\n",
    "# scale ch4 project fluxes down to account for unmatched methane credits\n",
    "ch4_scale = ch4_matched / pf_lfl['ch4_flux'].abs().sum()\n",
    "lfl['ch4_flux_lfl'] = lfl['ch4_flux'] * ch4_scale\n",
    "\n",
    "# scale long-lived justified emissions down to match long-lived supply\n",
    "longlived_demand_scale = longlived_matched / total_longlife_demand\n",
    "lfl['co2_justified_lfl'] = lfl['co2_justified'] * longlived_demand_scale\n",
    "lfl['n2o_justified_lfl'] = lfl['n2o_justified'] * longlived_demand_scale\n",
    "\n",
    "# co2 and cfc-12 project fluxes, plus justified ch4 fluxes, are unchanged\n",
    "lfl['co2_flux_lfl']   = lfl['co2_flux']\n",
    "lfl['cfc12_flux_lfl'] = lfl['cfc-12_flux']\n",
    "lfl['ch4_flux_lfl'] = lfl['ch4_justified']\n",
    "\n",
    "# co2 and cfc-12 project fluxes are unchanged; ch4 justified emissions are unchanged\n",
    "lfl['co2_flux_lfl']   = lfl['co2_flux']\n",
    "lfl['cfc12_flux_lfl'] = lfl['cfc-12_flux']\n",
    "lfl['ch4_justified_lfl'] = lfl['ch4_justified']\n",
    "\n",
    "lfl = lfl[[\n",
    "    'year',\n",
    "    'co2_flux_lfl',\n",
    "    'ch4_flux_lfl',\n",
    "    'cfc12_flux_lfl',\n",
    "    'co2_justified_lfl',\n",
    "    'ch4_justified_lfl',\n",
    "    'n2o_justified_lfl',\n",
    "]]\n",
    "\n",
    "lfl.to_csv('output-data/ca_likeforlike_fluxes.csv', index=False)"
   ]
